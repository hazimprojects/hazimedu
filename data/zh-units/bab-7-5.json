    {
      "source_id": "bab-7-5-u25",
      "bm_original": "💡 Kegigihan dan kebijaksanaan pemimpin terdahulu dalam membina asas kerjasama politik, ekonomi dan sosial wajar dihargai kerana menjadi landasan penting kepada kemerdekaan negara kita.",
      "zh_explain": "kemerdekaan（独立）；kerjasama（合作）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "kemerdekaan = 独立",
        "kerjasama = 合作",
        "pemimpin = 领导人",
        "ekonomi = 经济"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-7-5-u26",
      "bm_original": "🏛️ Selepas Perang Dunia Kedua , banyak parti politik ditubuhkan hasil perkembangan nasionalisme dan keinginan membebaskan tanah air daripada penjajahan.",
      "zh_explain": "perang dunia kedua（第二次世界大战）；nasionalisme（民族主义）",
      "key_points_zh": [
        "perang dunia kedua = 第二次世界大战",
        "nasionalisme = 民族主义",
        "perkembangan = 发展",
        "penjajahan = 殖民统治"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-7-5-u27",
      "bm_original": "🇲🇾 Walaupun banyak parti bermula dengan asas kaum atau wilayah, kebanyakannya menuju kepada matlamat yang sama, iaitu mencapai kemerdekaan dan membina negara yang berdaulat.",
      "zh_explain": "kemerdekaan（独立）；berdaulat（具主权的）",
      "key_points_zh": [
        "kemerdekaan = 独立",
        "berdaulat = 具主权的",
        "wilayah = 领土",
        "kaum = 族群"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-7-5-u28",
      "bm_original": "🤝 Perkembangan ini akhirnya mendorong kerjasama politik antara parti dan antara kaum , yang menjadi asas penting kepada perjuangan kemerdekaan negara.",
      "zh_explain": "perkembangan（发展）；kemerdekaan（独立）",
      "key_points_zh": [
        "perkembangan = 发展",
        "kemerdekaan = 独立",
        "perjuangan = 斗争",
        "kerjasama = 合作"
